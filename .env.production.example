# ============================================================
# ScanStruct 生产环境配置模板 — 请填入真实凭据后使用
# ============================================================
# 使用说明:
#   cp .env.production.example .env.production
#   # 编辑 .env.production 填入真实凭据
#   docker compose --env-file .env.production up -d --build
# ============================================================

# ---------- 基础 ----------
APP_NAME=ScanStruct
APP_ENV=production
APP_VERSION=0.1.0

# ---------- PostgreSQL ----------
POSTGRES_USER=scanstruct
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=scanstruct
POSTGRES_HOST_PORT=127.0.0.1:5432

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_HOST_PORT=127.0.0.1:6379

# ---------- MinIO ----------
MINIO_ROOT_USER=scanstruct_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_HOST_PORT=127.0.0.1:9000
MINIO_CONSOLE_HOST_PORT=127.0.0.1:9002

# ---------- API 服务 ----------
API_HOST_PORT=8900
API_KEY=CHANGE_ME_AT_LEAST_16_CHARS

# ---------- JWT ----------
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS

# ---------- 数据库连接池（4核8G 优化）----------
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# ---------- OCR 引擎 ----------
OCR_ENGINE_TYPE=multi
OCR_USE_GPU=false
OCR_BATCH_SIZE=100
OCR_MULTI_ENGINES=["baidu","rapid","glm"]

# ---------- 百度云 OCR ----------
BAIDU_OCR_APP_ID=CHANGE_ME
BAIDU_OCR_API_KEY=CHANGE_ME
BAIDU_OCR_SECRET_KEY=CHANGE_ME
BAIDU_OCR_TIMEOUT=30
BAIDU_OCR_MAX_CONCURRENT=10

# ---------- 百炼 OCR ----------
BAILIAN_API_KEY=CHANGE_ME
BAILIAN_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_OCR_MODEL=qwen-vl-ocr-latest

# ---------- 百炼文本模型 ----------
BAILIAN_TEXT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_TEXT_MODEL=qwen-plus-latest

# ---------- 模板输出 ----------
TEMPLATE_OUTPUT_DIR=/app/template_output

# ---------- 上传限制 ----------
MAX_UPLOAD_SIZE=524288000
MAX_BATCH_UPLOAD_SIZE=5368709120

# ---------- Celery ----------
CELERY_QUEUE_NAME=scanstruct
CELERY_TASK_TIMEOUT_SECONDS=7200

# ---------- 预处理 ----------
PREPROCESS_DPI=200
PREPROCESS_DESKEW=false
PREPROCESS_DENOISE=true
PREPROCESS_BINARY=true
PREPROCESS_CROP_BORDER=true
PREPROCESS_TARGET_SHORT_SIDE=1600
PREPROCESS_CLAHE_CLIP=2.0
PREPROCESS_SHARPEN=true
PREPROCESS_MORPH_CLEAN=true
SKIP_CLASSIFY=false

# ---------- 回调 ----------
CALLBACK_TIMEOUT_SECONDS=10
CALLBACK_RETRY_DELAYS=10,30,60
ALERT_WEBHOOK_URL=

# ---------- 业务 ----------
MAX_RETRY_COUNT=3
RETENTION_DAYS=30

# ---------- CI/CD 镜像（GHCR）----------
# 首次部署或手动构建时注释掉这两行（使用本地构建）
# CI/CD 自动部署时取消注释（使用 GHCR 远程镜像）
# API_IMAGE=ghcr.io/minlan01/ocr/scanstruct-api:latest
# WORKER_IMAGE=ghcr.io/minlan01/ocr/scanstruct-worker:latest
